{
  "name": "skillforge",
  "version": "2.0.0",
  "description": "Cloudflare-first skill extraction, scoring, and AutoResearch engine",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "mcp": "tsx src/mcp-server/server.ts",
    "build": "tsc --project tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts",
    "start": "node dist/index.js"
  },
  "keywords": [
    "skillforge",
    "cloudflare",
    "ai-gateway",
    "skill-extraction"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/node": "22.13.10",
    "@types/sql.js": "1.4.9",
    "@typescript-eslint/eslint-plugin": "8.25.0",
    "@typescript-eslint/parser": "8.25.0",
    "eslint": "9.39.0",
    "prettier": "3.5.2",
    "tsx": "4.21.0",
    "typescript": "5.7.3",
    "vitest": "3.0.8"
  },
  "dependencies": {
    "@hono/node-server": "1.19.11",
    "@modelcontextprotocol/sdk": "1.28.0",
    "bullmq": "5.53.3",
    "hono": "4.12.9",
    "ioredis": "5.6.0",
    "openai": "4.86.1",
    "sql.js": "1.13.0",
    "zod": "3.25.67"
  }
}
