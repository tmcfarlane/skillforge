{
  "name": "@skillforge/cli",
  "version": "0.1.0",
  "description": "CLI for managing and validating SkillForge skills",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "skillforge": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "dev": "tsc --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@skillforge/core": "workspace:*",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
