{
  "name": "@skillforge/mcp",
  "version": "0.1.0",
  "description": "MCP server exposing SkillForge capabilities to Claude Desktop",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "skillforge-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "dev": "tsc --watch",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@skillforge/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
